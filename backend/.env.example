# Gemini AI
GEMINI_API_KEY=your_gemini_api_key_here

# Firebase Admin SDK (paste entire service account JSON as one line)
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"your_project_id","private_key":"your_private_key","client_email":"your_client_email"}
FIREBASE_DB_URL=https://your-firebase-url-default-rtdb.firebaseio.com/

# Google Sheets
GOOGLE_SERVICE_ACCOUNT={"type":"service_account","project_id":"your_project_id","private_key":"your_private_key","client_email":"your_client_email"}
SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here
